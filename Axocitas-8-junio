            async function renderSplashTareas() {
                var cont = document.getElementById('splashTareas');
                if (!cont) return;
                cont.style.display = 'block';
                cont.innerHTML = '<div class="splash-tareas-empty">Cargando tareas...</div>';
                try {
                    var mod  = await import('https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js');
                    var snap = await mod.getDocs(mod.collection(db, 'axocitas_tareas'));
                    var hoy  = getFechaLocal();
                    var ds   = new Date(hoy + 'T00:00:00').getDay();
                    var tareas = snap.docs.map(function(d){ return d.data(); })
                        .filter(function(t){
                            if (t.recepcionista !== recepActual.nombre) return false;
                            if (t.repetir === 'diaria') return true;
                            if (t.repetir === 'semanal') return new Date(t.fecha+'T00:00:00').getDay() === ds;
                            return (!t.repetir || t.repetir === 'ninguna') && t.fecha === hoy;
                        });
                    var oP = {alta:0, media:1, baja:2};
                    tareas.sort(function(a,b){
                        if (a.completada !== b.completada) return a.completada ? 1 : -1;
                        return (oP[a.prioridad]||1) - (oP[b.prioridad]||1);
                    });
                    var inicial = recepActual.nombre ? recepActual.nombre.charAt(0).toUpperCase() : 'R';
                    var html = '<div style="display:flex;justify-content:center;margin-bottom:12px">'
                             + '<div class="splash-recep-chip"><div class="splash-recep-avatar">' + inicial + '</div>'
                             + recepActual.nombre + '</div></div>';
                    if (!tareas.length) {
                        html += '<div class="splash-tareas-titulo">Tareas del día</div>'
                              + '<div class="splash-tareas-empty">🎉 Sin tareas pendientes</div>';
                    } else {
                        html += '<div class="splash-tareas-titulo">Tareas del día (' + tareas.length + ')</div>';
                        tareas.forEach(function(t) {
                            html += '<div class="splash-tarea-item">'
                                  + '<div class="splash-tarea-dot ' + (t.prioridad||'media') + '"></div>'
                                  + '<div class="splash-tarea-texto">' + t.descripcion + '</div>'
                                  + (t.completada ? '<div class="splash-tarea-check">✓</div>' : '')
                                  + '</div>';
                        });
                    }
                    cont.innerHTML = html;
                } catch(e) {
                    cont.innerHTML = '<div class="splash-tareas-empty">No se pudieron cargar las tareas.</div>';
                }
            }

