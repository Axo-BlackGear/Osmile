            async function cargarTareasRecep() {
                var panel=document.getElementById('tareasPanel');
                var body=document.getElementById('tareasPanelBody');
                var badge=document.getElementById('tareasBadgeCount');
                if (!recepActual||recepActual.esAdmin) { if(panel) panel.style.display='none'; return; }
                if (!panel||!body) return;
                panel.style.display='block';
                body.innerHTML='<div class="tareas-empty">Cargando...</div>';
                try {
                    var mod=await import('https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js');
                    var snap=await mod.getDocs(mod.collection(db,'axocitas_tareas'));
                    var hoy=getFechaLocal();
                    var ds=new Date(hoy+'T00:00:00').getDay();
                    var tareas=snap.docs.map(function(d){ return d.data(); }).filter(function(t){ return t.recepcionista===recepActual.nombre; });
                    for (var i=0;i<tareas.length;i++) {
                        var t=tareas[i];
                        if ((!t.repetir||t.repetir==='ninguna')&&t.fecha<hoy) {
                            try{ await mod.deleteDoc(mod.doc(db,'axocitas_tareas',t.id)); }catch(_){}
                        }
                    }
                    tareas=tareas.filter(function(t){
                        if (t.repetir==='diaria') return true;
                        if (t.repetir==='semanal') return new Date(t.fecha+'T00:00:00').getDay()===ds;
                        return (!t.repetir||t.repetir==='ninguna')&&t.fecha===hoy;
                    });
                    tareas.sort(function(a,b){ return (a.completada===b.completada?0:a.completada?1:-1)||({alta:0,media:1,baja:2}[a.prioridad]||1)-({alta:0,media:1,baja:2}[b.prioridad]||1); });
                    var pend=tareas.filter(function(t){ return !t.completada; }).length;
                    if (badge){ badge.textContent=pend||''; badge.classList.toggle('visible',pend>0); }
                    if (!tareas.length){ body.innerHTML='<div class="tareas-empty"><i class="ph-bold ph-check-circle" style="font-size:1.8rem;display:block;margin-bottom:6px;opacity:.4"></i>Sin tareas para hoy 🎉</div>'; return; }
                    body.innerHTML='';
                    var ch={alta:'chip-alta',media:'chip-media',baja:'chip-baja'};
                    var pL={alta:'Alta 🔴',media:'Media 🟡',baja:'Baja 🟢'};
                    tareas.forEach(function(t){
